PORT=4000

# Allowed CORS origins (comma-separated), or "*" to allow any origin (useful
# when distributing the widget for third-party sites to embed).
FRONTEND_ORIGIN=http://localhost:3100

# Absolute base URL of this backend (no trailing slash) — used when building
# admin reply URLs that get printed in the Telegram caption. Required in
# production behind a reverse proxy. Leave unset in dev.
# PUBLIC_BASE_URL=https://gmic.ai/voice2us

# Primary Telegram recipient. Get a bot token from @BotFather and the user's
# numeric chat_id via getUpdates (see README.md).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Additional recipients (optional). Each recipient is an independent bot+chat
# pair — each person must have started their own bot first. Add as many as
# needed by incrementing the suffix (_2, _3, _4, ...). Both variables in a
# pair must be set or the pair is ignored.
# TELEGRAM_BOT_TOKEN_2=
# TELEGRAM_CHAT_ID_2=
# TELEGRAM_BOT_TOKEN_3=
# TELEGRAM_CHAT_ID_3=

# OpenAI API key for Whisper transcription. If unset, voice messages are sent
# without a transcript.
OPENAI_API_KEY=

# Whisper model. Defaults to whisper-1.
# OPENAI_TRANSCRIBE_MODEL=whisper-1

# Google OAuth Client ID — must match the client_id baked into the widget.
# Server uses this as the audience check when verifying Google ID tokens.
GOOGLE_CLIENT_ID=

# Local-test guard: by default, uploads from a localhost page never reach
# Telegram or OpenAI (logs only). Set to true to exercise the full flow.
# ALLOW_LOCAL_SENDS=true
