PORT=4000

# Allowed CORS origins (comma-separated), or "*" to allow any origin (useful
# when distributing the widget for third-party sites to embed).
FRONTEND_ORIGIN=http://localhost:3100

# Get a bot token from @BotFather on Telegram (see backend/README.md).
TELEGRAM_BOT_TOKEN=

# Numeric chat_id of the Telegram user who should receive the voice messages.
# See backend/README.md for how to obtain it.
TELEGRAM_CHAT_ID=
